# Quran Foundation API (backend only)
QURAN_CONTENT_ENV=production
QURAN_CONTENT_API_BASE_URL=https://apis.quran.foundation/content/api/v4
QURAN_API_BASE_URL=https://apis.quran.foundation/content/api/v4
QURAN_OAUTH_ENDPOINT=https://prelive-oauth2.quran.foundation
QURAN_OAUTH_CLIENT_ID=your_client_id
QURAN_OAUTH_CLIENT_SECRET=your_client_secret
QURAN_PRODUCTION_OAUTH_ENDPOINT=https://oauth2.quran.foundation
QURAN_PRODUCTION_OAUTH_CLIENT_ID=your_production_client_id
QURAN_PRODUCTION_OAUTH_CLIENT_SECRET=your_production_client_secret

# OAuth2 (Quran Foundation)
EXPO_PUBLIC_OAUTH_CLIENT_ID=your_client_id
EXPO_PUBLIC_QURAN_OAUTH_ENDPOINT=https://prelive-oauth2.quran.foundation
EXPO_PUBLIC_OAUTH_REDIRECT_URI=noor://oauth/callback
# Keep QURAN_OAUTH_CLIENT_SECRET in the backend .env only. Do not prefix it with EXPO_PUBLIC.

# AI Backend
EXPO_PUBLIC_BACKEND_URL=http://localhost:3001
BACKEND_API_KEY=your_backend_secret

# Anthropic (backend only — never expose in app)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Quran MCP Server
MCP_SERVER_URL=https://mcp.quranfoundation.org

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Redis (Upstash)
REDIS_URL=rediss://...
REDIS_TOKEN=your_upstash_token
